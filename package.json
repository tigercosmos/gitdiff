{
  "name": "gitdiff",
  "displayName": "GitDiff",
  "description": "Diff your working-tree file against any branch or commit, with the working-tree side editable.",
  "version": "0.3.0",
  "publisher": "tigercosmos",
  "icon": "icons/activity.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["SCM Providers", "Other"],
  "repository": {
    "type": "git",
    "url": "https://github.com/tigercosmos/gitdiff.git"
  },
  "main": "./out/src/extension.js",
  "activationEvents": ["onStartupFinished"],
  "capabilities": {
    "virtualWorkspaces": false,
    "untrustedWorkspaces": {
      "supported": false,
      "description": "GitDiff shells out to the local git binary."
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "gitdiff.compareWithBranch",
        "title": "GitDiff: Compare with Branch…"
      },
      {
        "command": "gitdiff.compareWithCommit",
        "title": "GitDiff: Compare with Commit…"
      },
      {
        "command": "gitdiff.refresh",
        "title": "GitDiff: Refresh Diff",
        "icon": "$(refresh)"
      },
      {
        "command": "gitdiff.changeTarget",
        "title": "GitDiff: Change Target…",
        "icon": "$(git-compare)"
      },
      {
        "command": "gitdiff.changedFiles.setTarget",
        "title": "GitDiff: Set Comparison Target…",
        "icon": "$(git-compare)"
      },
      {
        "command": "gitdiff.changedFiles.refresh",
        "title": "GitDiff: Refresh Changed Files",
        "icon": "$(refresh)"
      },
      {
        "command": "gitdiff.changedFiles.openFile",
        "title": "GitDiff: Open Diff for File"
      },
      {
        "command": "gitdiff.changedFiles.clearTarget",
        "title": "GitDiff: Clear Comparison Target",
        "icon": "$(clear-all)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitdiff",
          "title": "GitDiff",
          "icon": "icons/activity.svg"
        }
      ]
    },
    "views": {
      "gitdiff": [
        {
          "type": "webview",
          "id": "gitdiff.changedFiles",
          "name": "Changed Files",
          "contextualTitle": "GitDiff"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "gitdiff.compareWithBranch",
          "when": "resourceScheme == file && !explorerResourceIsFolder"
        },
        {
          "command": "gitdiff.compareWithCommit",
          "when": "resourceScheme == file && !explorerResourceIsFolder"
        },
        {
          "command": "gitdiff.refresh",
          "when": "gitdiff.activeDiff"
        },
        {
          "command": "gitdiff.changeTarget",
          "when": "gitdiff.activeDiff"
        }
      ],
      "explorer/context": [
        {
          "command": "gitdiff.compareWithBranch",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "3_compare@1"
        },
        {
          "command": "gitdiff.compareWithCommit",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "3_compare@2"
        }
      ],
      "editor/title/context": [
        {
          "command": "gitdiff.compareWithBranch",
          "when": "resourceScheme == file",
          "group": "3_compare@1"
        },
        {
          "command": "gitdiff.compareWithCommit",
          "when": "resourceScheme == file",
          "group": "3_compare@2"
        }
      ],
      "editor/title": [
        {
          "command": "gitdiff.refresh",
          "when": "gitdiff.activeDiff",
          "group": "navigation@1"
        },
        {
          "command": "gitdiff.changeTarget",
          "when": "gitdiff.activeDiff",
          "group": "navigation@2"
        }
      ],
      "view/title": [
        {
          "command": "gitdiff.changedFiles.setTarget",
          "when": "view == gitdiff.changedFiles",
          "group": "navigation@1"
        },
        {
          "command": "gitdiff.changedFiles.refresh",
          "when": "view == gitdiff.changedFiles && gitdiff.hasTarget",
          "group": "navigation@2"
        },
        {
          "command": "gitdiff.changedFiles.clearTarget",
          "when": "view == gitdiff.changedFiles && gitdiff.hasTarget",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "GitDiff",
      "properties": {
        "gitdiff.commitPickerLimit": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 5000,
          "description": "Maximum number of recent commits shown in the commit picker."
        },
        "gitdiff.gitPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Absolute path to the git executable. Leave empty to resolve from PATH. Machine-scoped: workspace settings cannot override it (a workspace-controlled binary path would be a privilege-escalation vector)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node ./out/test/integration/runTest.js",
    "test:unit": "mocha --require ts-node/register 'test/unit/**/*.test.ts'",
    "package": "vsce package",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "minimatch": "^3.1.5"
  },
  "devDependencies": {
    "@types/minimatch": "^3.0.5",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^2.24.0",
    "mocha": "^10.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
